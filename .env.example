# .env.example
# 이 파일을 복사해서 .env로 만들고 실제 값 입력
# cp .env.example .env

OPENAI_API_KEY=sk-...
NOTION_TOKEN=secret_...
GOOGLE_SERVICE_ACCOUNT_JSON=./credentials.json

# ── Eval Agent (진단) ─────────────────────────────────────────────
# 아래는 전부 선택(주석 상태의 값이 기본값). 기본값만으로도 외부 API 없이 폴백 동작.

# 진단 깊이(비용 tier): fast|standard|deep|full 또는 1~4
#   fast=규칙만 · standard=+추가검색(BM25·코퍼스) · deep=+RAGAS(LLM) · full=+재실행(ablation)
# EVAL_MODE=fast

# RAGAS(LLM-as-Judge) 진단 허용. 1/true 여야 하며, 실제 실행은 EVAL_MODE>=deep 과 AND.
# EVAL_ENABLE_LLM=0

# Eval Agent LLM provider (기본 openai). OpenAI 토큰 승인 전 임시로 github 사용 가능
# EVAL_LLM_PROVIDER=github
GEMINI_API_KEY=...
# GitHub Models(무료, OpenAI 호환 API) — https://github.com/settings/tokens 에서 발급한
# 개인 액세스 토큰(추가 scope 불필요)
GITHUB_TOKEN=...

# LLM 모델 (OPENAI_API_KEY 필요). 응답 모델 != 평가(심판) 모델 원칙.
# EVAL_GEN_MODEL=gpt-4o-mini
# EVAL_JUDGE_MODEL=gpt-4o
# EVAL_EMBED_MODEL=text-embedding-3-small
# EVAL_GEN_MODEL_GITHUB=openai/gpt-4o-mini
# EVAL_JUDGE_MODEL_GITHUB=openai/gpt-4o

# RAGAS Response Relevancy: 답변당 질문 생성 횟수(strictness)
# EVAL_RELEVANCY_STRICTNESS=3

# 테스트(test_ragas_eval)에서 LLM 입출력 로깅
# EVAL_DEBUG=

# 검색 인덱스(Qdrant) 대상 — 기본은 인메모리(:memory:)
# QDRANT_URL=:memory:
# QDRANT_API_KEY=

# ── Index Agent (임베딩) ──────────────────────────────────────────
# HuggingFace 토큰. 기본 임베딩 모델(paraphrase-multilingual-MiniLM-L12-v2)은 공개라 불필요.
# gated/private 모델 사용 시 또는 다운로드 rate limit 회피용에만. (load_dotenv 후 os.environ 으로 인식)
# HF_TOKEN=hf_...
