## .env.example
## 이 파일을 복사해서 .env로 만들고 실제 값 입력
## cp .env.example .env
##
## 규칙: 주석 처리된 값(# VAR=...)이 코드 기본값. 필요한 것만 주석 해제.
## 키가 하나도 없어도 전 파이프라인이 폴백(휴리스틱/추출식)으로 동작한다.

## ── API 키 (여러 Agent 공용) ──────────────────────────────────────
## 주의: OPENAI_API_KEY는 "존재하기만 하면" Index의 LLM graph 추출 등이 활성화됨.
##       자리표시자(sk-...)를 넣어두면 401만 반복되니, 진짜 키가 없으면 아예 비워둘 것.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GITHUB_TOKEN=

## ── Ingest Agent (수집) ───────────────────────────────────────────
## Notion: 내부 통합 토큰(ntn_/secret_...) 또는 OAuth 앱(CLIENT_ID/SECRET 브라우저 플로우)
# NOTION_TOKEN=
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
## tests/test_pipeline.py 가 수집할 Notion 페이지 URL
# TEST_NOTION_URL=

## 파이프라인 소스(run_local_pipeline.py / graph.py 공용) — state.source_type/source_url 로 들어감.
##   미설정 시 기본값은 file(sample_docs/hr_policy.md) — 레포에 포함돼 클론 직후 바로 실행된다.
##   korquad 는 data/corpus.jsonl·data/qa_pairs.jsonl 을 직접 준비해야 한다(data/README.md 참고).
##   SOURCE_TYPE=korquad 이면 Eval 이 자동으로 taxonomy 소스를 쓰도록 세팅되고,
##   corpus 는 SOURCE_URL 하나로 통일 — Ingest(문서 복원)와 Eval(gold 좌표)이 같은 파일을 본다.
# SOURCE_TYPE=file                ## file | korquad | notion | json_corpus
# SOURCE_URL=sample_docs/hr_policy.md
# KORQUAD_MAX_DOCS=      ## (korquad) 앞 N개 문서만(스모크). 0/미설정=전체. corpus·qa 동일 규칙

## ── Index Agent (청킹·임베딩) ─────────────────────────────────────
## HuggingFace 토큰(BGE-M3 다운로드 rate limit 완화용, 선택)
# HF_TOKEN=hf_...
## Qdrant — 기본은 프로세스 내 인메모리(:memory:). Index·Eval·RAG·Serve 공용.
# QDRANT_URL=:memory:
# QDRANT_API_KEY=
## 색인 시 청크 임베딩 배치 크기. 1이면 단건 인코딩 루프(기존 동작과 bit-identical).
## >1 은 근사 — 배치 패딩/누적 순서로 벡터에 ~1e-7 수준 미세차 가능(검색 품질엔 무시 수준).
# INDEX_EMBED_BATCH=32
## 임베딩 모델 로드 실패 후 재시도까지의 쿨다운(초). 실패 시 해시 기반 fallback
## 임베딩(의미 검색 불가)이 쓰이므로, 일시적 실패(네트워크 등)에서 복구되도록 재시도한다.
# INDEX_EMBED_MODEL_RETRY_SEC=300
## reranker(use_reranker=True) 모델 로드 실패 후 재시도까지의 쿨다운(초). 위와 동일 정책 —
## 일시적 실패 후에도 프로세스 내내 리랭킹이 죽지 않도록 쿨다운이 지나면 재시도한다.
# INDEX_RERANKER_RETRY_SEC=300

## ── Eval Agent (진단) ─────────────────────────────────────────────
## 아래는 전부 선택(주석 처리된 값이 코드 기본값). 기본값만으로도 외부 API 없이 폴백 동작.

## Probe 소스: auto | user_log | made | taxonomy (미지정=자동 판별)
##   auto     = 지식그래프 기반 자동 생성(user_questions 무시). GT·gold 포함 → recall/F1/RAGAS 전량 평가.
##   user_log = 실사용 질문(user_questions) 사용. GT 없음 → reference-free RAGAS만.
##   made     = eval_probes.json 을 코퍼스 버전과 무관하게 고정 테스트셋으로 재사용
##              (임계값 캘리브레이션 등 실행 간 비교가 필요할 때 권장. LLM 비용도 0).
##   taxonomy = 외부 사람작성 QA 데이터셋(KorQuAD 등). qa=EVAL_TAXONOMY_QA, corpus=SOURCE_URL(위) 재사용.
##   미지정   = user_questions 있으면 user_log, 없으면 auto (기존 동작).
## EVAL_PROBE_SOURCE=

## KorQuAD(taxonomy) 세부 — qa 파일과 규모.
# EVAL_TAXONOMY_QA=data/qa_pairs.jsonl
# KORQUAD_QA_LIMIT=      ## qa 개수 상한. 0/미설정=전체

## 자동 생성 QA셋(probe) 개수. 임계값 캘리브레이션 시 30~50 권장
## (n이 작으면 overall 점수가 QA셋 뽑기 운에 크게 출렁임: n=10 → ±16%p, n=30 → ±9%p 수준)
EVAL_TESTSET_SIZE=30

## 진단 깊이(비용 tier): fast|standard|deep|full 또는 1~4
# EVAL_MODE=fast

## RAGAS(LLM-as-Judge) 진단 허용. 1/true 여야 하며, 실제 실행은 EVAL_MODE>=deep 과 AND.
# EVAL_ENABLE_LLM=0

## LLM provider 선택: openai | gemini | github
# EVAL_LLM_PROVIDER=openai

## LLM 모델 ("응답 모델 != 심판 모델"이 원칙, 선택한 provider 파트만 채우기).
## OpenAI
# EVAL_GEN_MODEL=gpt-4o-mini
# EVAL_JUDGE_MODEL=gpt-4o
# EVAL_EMBED_MODEL=text-embedding-3-small
## Gemini — 주의: 기본값 gemini-flash-latest 별칭은 서버에서 gemini-2.5-flash 로
## 해석되는데, 신규 발급 키에는 그 모델이 차단돼 404가 남. 신규 키면 아래처럼
## 명시적 최신 모델을 지정할 것 (사용 가능 목록: client.models.list()).
# EVAL_GEN_MODEL_GEMINI=gemini-3.5-flash         # 답변 생성(generate_answer)
# EVAL_JUDGE_MODEL_GEMINI=gemini-3.5-flash       # probe 생성 + RAGAS 심판 (chat_json 경로)
# EVAL_EMBED_MODEL_GEMINI=gemini-embedding-001   # response_relevancy 임베딩
## GitHub Models
# EVAL_GEN_MODEL_GITHUB=openai/gpt-4o-mini
# EVAL_JUDGE_MODEL_GITHUB=openai/gpt-4o

## RAGAS Response Relevancy: 답변당 질문 생성 횟수(strictness)
# EVAL_RELEVANCY_STRICTNESS=3

## LLM 호출 동시 실행 수 (STEP1 probe 합성 + STEP2 답변 생성 + STEP3-2 RAGAS probe×track).
## 1이면 완전 순차. 무료 티어처럼 분당 한도(RPM)가 낮으면 2~3 권장 — 429 재시도 로그가
## 잦으면 낮출 것. 유료 티어(RPM 1000급)면 8~16까지 올려도 됨.
# EVAL_LLM_CONCURRENCY=10

## RAGAS 트랙 1개 내부(지표 4개·청크별 판정·strictness 반복) 동시성. 기본 1(=off).
## 실효 동시 요청 = EVAL_LLM_CONCURRENCY × 이 값(곱)이므로 함께 올리면 RPM 한도 주의.
## probe 수가 적어 바깥 병렬이 놀 때(소수 probe 검증)만 2~4 권장.
# EVAL_RAGAS_INNER_CONCURRENCY=1

## LLM rate limit(429) 재시도 — Gemini 무료 티어 등에서 "too many requests" 대응
# EVAL_LLM_RETRY_WAIT=5      # 재시도 전 대기 시간(초, 실제 대기는 ×1~2 jitter)
# EVAL_LLM_MAX_RETRIES=5     # 재시도 횟수 상한(소진하면 폴백)

## 테스트(test_ragas_eval)에서 LLM 입출력 로깅
# EVAL_DEBUG=

## ── LLM 사용량·비용 로깅 (core/llm_usage.py — Eval·RAG 공용) ──────
## 토큰 수와 추정 비용(단가표 × 토큰)을 집계한다.
##   0/false/off : 전부 끔
##   1 (기본)     : STEP 단위 요약 — 각 단계 끝에 호출수·토큰·비용·시간 한 줄
##   verbose      : 위에 더해 LLM 호출 1건마다 토큰 줄 출력(디버깅용, 매우 시끄러움)
# LLM_LOG_USAGE=1

## ── RAG (검색 + 답변 생성 — Eval STEP2 와 Serve /answer 공용) ─────
## provider 선택: auto(기본) | openai | gemini | github
##   auto = OpenAI → Gemini → GitHub 순서로 키가 있는 provider 시도.
# RAG_LLM_PROVIDER=auto

## 모든 provider 공통 모델 오버라이드(지정 시 아래 provider별 모델보다 우선, auto 모드 제외).
# RAG_LLM_MODEL=

## OpenAI (openai SDK — 필요 시 표준 OPENAI_BASE_URL을 SDK가 자동 인식)
# RAG_OPENAI_MODEL=gpt-4o
## Gemini — 위 Eval 의 gemini-flash-latest 주의사항 동일. 신규 키면 명시 지정.
# RAG_GEMINI_MODEL=gemini-3.5-flash
## GitHub Models (토큰: GITHUB_MODELS_TOKEN 우선, 없으면 위 GITHUB_TOKEN.
##  auto 모드에선 전용 토큰(GITHUB_MODELS_TOKEN)이 있을 때만 GitHub 를 시도)
# GITHUB_MODELS_TOKEN=
# RAG_GITHUB_MODEL=openai/gpt-4o

## ── Serve Agent (API 서버·MCP) ────────────────────────────────────
## FastAPI 서버 포트 (/health /documents /search /answer)
# AGENT_DOCTOR_API_PORT=8766
## API 서버 기동 대기 시간(초). api.py 는 리스닝 전에 청크 로드·retriever 구축을
## 하므로 코퍼스가 크면 늘려야 할 수 있다. 초과 시 Serve 는 error 로 종료.
# AGENT_DOCTOR_API_START_TIMEOUT=30
## MCP stdio 서버(mcp_server.py)가 바라볼 API 주소·청크 파일 (기본값으로 충분)
# AGENT_DOCTOR_API_URL=http://localhost:8766
# AGENT_DOCTOR_CHUNKS_FILE=chunks.json
